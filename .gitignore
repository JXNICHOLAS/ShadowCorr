# ── Runtime output directories (created automatically by the code) ─────────
outputs/            # Hydra train runs:   outputs/train/<date>/<time>/
multirun/           # Hydra --multirun sweep runs
eval_outputs/       # eval_app output JSONs

# ── Preprocessed data (generated by shadowcorr preprocess) ─────────────────
data/voxel_npz_scene/

# ── Full-dataset NPZ files (too large for git; download from Zenodo) ────────
# Sample files under data/in_segments/ ARE committed (small, for quick testing).
# Only ignore the large train/valid/test splits.
data/in_segments/train/
data/in_segments/valid/
data/in_segments/test/

# ── Model weights ───────────────────────────────────────────────────────────
*.pth
*.ckpt
# keep committed pretrained model
!checkpoints/*.pth

# ── Python build / cache ────────────────────────────────────────────────────
*.egg-info/
__pycache__/
*.py[cod]
*.pyc
dist/
build/
.pytest_cache/

# ── Tools ───────────────────────────────────────────────────────────────────
.venv/
.torch/
wandb/
.DS_Store
*.code-workspace
*.tex
*.bib
