# ── Runtime output directories (created automatically by the code) ─────────
# Hydra train runs:   outputs/train/<date>/<time>/
outputs/
# Hydra --multirun sweep runs
multirun/
# eval_app output JSONs
eval_outputs/

# ── Preprocessed data (generated by shadowcorr preprocess) ─────────────────
data/voxel_npz_scene/

# ── Full-dataset NPZ files (too large for git; download from Zenodo) ────────
# Only test_sample/ under data/in_segments/ is committed.
# Flat NPZ files added by generate_segment_npz.py are gitignored.
data/in_segments/*.npz

# ── Model weights ───────────────────────────────────────────────────────────
*.pth
*.ckpt
# keep committed pretrained model
!checkpoints/*.pth

# ── Python build / cache ────────────────────────────────────────────────────
*.egg-info/
__pycache__/
*.py[cod]
*.pyc
dist/
build/
.pytest_cache/

# ── Tools ───────────────────────────────────────────────────────────────────
.venv/
.torch/
wandb/
.DS_Store
*.code-workspace
*.tex
*.bib
